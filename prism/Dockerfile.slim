# syntax=docker/dockerfile:1

# ──────────────────────────────────────────────────────────────────────────
# Prism SLIM image — Node standalone server + lightweight Fan Breakout.
#
# Used for the "hybrid" deployment on a low-RAM box (e.g. the Oracle E2.1.Micro):
# the dashboards + Office workspace run in the cloud. The heavy Playwright
# /scraper still stays on your Mac (no Chromium baked here — that button errors
# by design), BUT the Fan Breakout tool runs IN THE CLOUD: it only needs
# yfinance/pandas/numpy/requests, which are cheap enough for the tiny VM. The
# shivam.py script is vendored into ./breakout so it ships inside the image.
#
# Built by GitHub Actions (.github/workflows/docker.yml) for linux/amd64 and
# pushed to GHCR, so the tiny VM only ever PULLS — it never runs `next build`.
# ──────────────────────────────────────────────────────────────────────────

FROM node:22-bookworm-slim AS deps
WORKDIR /app
# better-sqlite3 is native; build tools as a fallback if no prebuilt matches.
RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 make g++ ca-certificates \
    && rm -rf /var/lib/apt/lists/*
COPY package.json package-lock.json ./
RUN npm ci

FROM node:22-bookworm-slim AS builder
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:22-bookworm-slim AS runner
WORKDIR /app
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    # Point the Fan Breakout tool at the in-image Python venv + vendored script.
    PRISM_FAN_BREAKOUT_PYTHON=/opt/venv/bin/python \
    PRISM_FAN_BREAKOUT_SCRIPT=/app/breakout/shivam.py

# Lightweight Python venv for Fan Breakout (yfinance/pandas/numpy/requests).
# Deliberately NO Playwright/Chromium — that heavy half stays out of the slim
# image, so the /scraper button still errors here while breakout works.
RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 python3-venv ca-certificates \
    && python3 -m venv /opt/venv \
    && /opt/venv/bin/pip install --no-cache-dir --upgrade pip \
    && /opt/venv/bin/pip install --no-cache-dir \
         pandas numpy requests yfinance \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /app/data /app/external
# Vendored breakout script + a writable cwd for hello.csv / breakout_results.csv.
COPY breakout/shivam.py /app/breakout/shivam.py
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
EXPOSE 3000
CMD ["node", "server.js"]
